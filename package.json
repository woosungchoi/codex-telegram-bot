{
  "name": "codex-telegram-bot",
  "version": "1.2.6",
  "license": "MIT",
  "type": "module",
  "description": "Telegram bridge for Codex CLI via @openai/codex-sdk",
  "homepage": "https://github.com/woosungchoi/codex-telegram-bot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/woosungchoi/codex-telegram-bot.git"
  },
  "bugs": {
    "url": "https://github.com/woosungchoi/codex-telegram-bot/issues"
  },
  "keywords": [
    "codex",
    "telegram",
    "bot",
    "codex-cli",
    "openai"
  ],
  "bin": {
    "codex-telegram-bot": "./bin/codex-telegram-bot",
    "codex-telegram-worker": "./bin/codex-telegram-worker"
  },
  "files": [
    ".env.example",
    ".env.minimal.example",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "README.md",
    "README.ko.md",
    "SECURITY.md",
    "assets",
    "bin",
    "docs",
    "scripts",
    "src",
    "systemd"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/bot.js",
    "start:worker": "node src/worker.js",
    "check": "node scripts/check-syntax.mjs && npm run validate:locales",
    "lint": "eslint \"src/**/*.js\" \"scripts/**/*.mjs\" \"test/**/*.mjs\" eslint.config.js --max-warnings=0",
    "format:check": "prettier --check package.json package-lock.json .github/workflows/*.yml",
    "validate:locales": "node scripts/validate-locales.mjs",
    "verify": "npm run check && npm run lint && npm run format:check && npm test && npm audit --audit-level=moderate",
    "test": "node --test"
  },
  "dependencies": {
    "@openai/codex-sdk": "0.144.1",
    "dotenv": "^17.2.3",
    "markdown-it": "^14.3.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@openai/codex": "0.144.1",
    "eslint": "10.7.0",
    "prettier": "3.9.5"
  }
}
